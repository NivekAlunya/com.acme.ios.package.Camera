    "alert_error_camera": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An error occurred when using the camera"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei der Verwendung der Kamera ist ein Fehler aufgetreten"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Παρουσιάστηκε σφάλμα κατά τη χρήση της κάμερας"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se produjo un error al usar la cámara"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si è verificato un errore durante l'uso della fotocamera"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is een fout opgetreden bij het gebruik van de camera"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocorreu um erro ao usar a câmera"
          }
        }
      }
    },
    "camera_error_cameraUnauthorized": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The camera access has been rejected.\\nPlease tap on the settings button below to activate the feature for the application."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kamerazugriff wurde abgelehnt.\\nBitte tippen Sie auf die Einstellungen unten, um die Funktion für die Anwendung zu aktivieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η πρόσβαση στην κάμερα απορρίφθηκε.\\nΠατήστε το κουμπί ρυθμίσεων παρακάτω για να ενεργοποιήσετε τη λειτουργία της εφαρμογής."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ha rechazado el acceso a la cámara.\\nToca el botón de ajustes a continuación para activar la función en la aplicación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alla fotocamera è stato negato.\\nTocca il pulsante delle impostazioni in basso per attivare la funzione per l'applicazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De cameratoegang is geweigerd.\\nTik op de instellingenknop hieronder om de functie in te schakelen voor deze app."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmera foi recusado.\\nNa tela abaixo, toque no botão de configurações para ativar o recurso no aplicativo."
          }
        }
      }
    },
    "camera_error_cameraUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This camera is unavailable."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Kamera ist nicht verfügbar."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η κάμερα δεν είναι διαθέσιμη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta cámara no está disponible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa fotocamera non è disponibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze camera is niet beschikbaar."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta câmera não está disponível."
          }
        }
      }
    },
    "camera_error_cannotAddInput": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The system can add this input to the session of the camera."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System kann diese Eingabe der Kamerasitzung hinzufügen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το σύστημα μπορεί να προσθέσει αυτήν την είσοδο στη συνεδρία της κάμερας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema puede agregar esta entrada a la sesión de la cámara."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema può aggiungere questo input alla sessione della fotocamera."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het systeem kan deze invoer toevoegen aan de camerasessie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema pode adicionar esta entrada à sessão da câmera."
          }
        }
      }
    },
    "camera_error_cannotAddOutput": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The system can add this output to the session of the camera."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System kann diese Ausgabe der Kamerasitzung hinzufügen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το σύστημα μπορεί να προσθέσει αυτήν την έξοδο στη συνεδρία της κάμερας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema puede agregar esta salida a la sesión de la cámara."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema può aggiungere questo output alla sessione della fotocamera."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het systeem kan deze uitvoer toevoegen aan de camerasessie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema pode adicionar esta saída à sessão da câmera."
          }
        }
      }
    },
